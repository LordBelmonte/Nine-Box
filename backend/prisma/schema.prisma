generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String                      @id @default(uuid())
  ra                    String                      @unique
  nome                  String
  email                 String                      @unique
  senha                 String
  tipo                  UserType
  foto                  String?
  cargo                 String?
  departamento          String?
  deletedAt             DateTime?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  campanhasResponsavel  CampaignGestor[]
  avaliacoesRecebidas   Evaluation[]                @relation("AvaliadoRelation")
  avaliacoesFeitas      Evaluation[]                @relation("AvaliadorRelation")
  gruposComoColaborador GestorColaborador[]         @relation("ColaboradorRelation")
  gruposComoGestor      GestorColaborador[]         @relation("GestorRelation")
  nineBoxAvaliacoes     NineBox[]
  colaboradoresAvaliaveis CampaignGestorColaborador[]
  refreshTokens         RefreshToken[]

  @@index([ra])
  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

model GestorColaborador {
  id            String   @id @default(uuid())
  gestorId      String
  colaboradorId String
  createdAt     DateTime @default(now())
  colaborador   User     @relation("ColaboradorRelation", fields: [colaboradorId], references: [id], onDelete: Cascade)
  gestor        User     @relation("GestorRelation", fields: [gestorId], references: [id], onDelete: Cascade)

  @@unique([gestorId, colaboradorId])
  @@index([gestorId])
  @@index([colaboradorId])
  @@map("gestor_colaborador")
}

model EvaluationCampaign {
  id           String               @id @default(uuid())
  nome         String
  descricao    String?
  dataInicio   DateTime
  dataFim      DateTime
  status       CampaignStatus       @default(planejamento)
  tipoAlvo     String
  tipoAvaliacao String?  // Tipo da avaliação (ex: "180", "360")
  deletedAt    DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  competencias CampaignCompetency[]
  gestores     CampaignGestor[]
  avaliacoes   Evaluation[]

  @@index([status])
  @@map("evaluation_campaigns")
}

model CampaignCompetency {
  id           String             @id @default(uuid())
  campaignId   String
  competencyId String
  createdAt    DateTime           @default(now())
  campaign     EvaluationCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  competency   Competency         @relation(fields: [competencyId], references: [id], onDelete: Cascade)

  @@unique([campaignId, competencyId])
  @@index([campaignId])
  @@index([competencyId])
  @@map("campaign_competencies")
}

model CampaignGestor {
  id                      String                     @id @default(uuid())
  campaignId               String
  gestorId                 String
  createdAt                DateTime                   @default(now())
  campaign                 EvaluationCampaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  gestor                   User                       @relation(fields: [gestorId], references: [id], onDelete: Cascade)
  colaboradoresAvaliaveis  CampaignGestorColaborador[]

  @@unique([campaignId, gestorId])
  @@index([campaignId])
  @@index([gestorId])
  @@map("campaign_gestores")
}

model CampaignGestorColaborador {
  id            String             @id @default(uuid())
  campaignGestorId String
  colaboradorId String
  createdAt     DateTime           @default(now())
  campaignGestor CampaignGestor    @relation(fields: [campaignGestorId], references: [id], onDelete: Cascade)
  colaborador   User               @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)

  @@unique([campaignGestorId, colaboradorId])
  @@index([campaignGestorId])
  @@index([colaboradorId])
  @@map("campaign_gestor_colaboradores")
}

model Evaluation {
  id          String             @id @default(uuid())
  campaignId  String
  avaliadorId String
  avaliadoId  String
  criterios   Json
  media       Float?
  comentario  String?
  anonima     Boolean            @default(true)
  data        DateTime           @default(now())
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  avaliado    User               @relation("AvaliadoRelation", fields: [avaliadoId], references: [id], onDelete: Cascade)
  avaliador   User               @relation("AvaliadorRelation", fields: [avaliadorId], references: [id], onDelete: Cascade)
  campaign    EvaluationCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, avaliadorId, avaliadoId])
  @@index([campaignId])
  @@index([avaliadoId])
  @@index([avaliadorId])
  @@index([data])
  @@map("evaluations")
}

model NineBox {
  id          String   @id @default(uuid())
  pessoaId    String
  performance Float
  potential   Float
  categoria   String
  comentario  String?
  data        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  pessoa      User     @relation(fields: [pessoaId], references: [id], onDelete: Cascade)

  @@index([pessoaId])
  @@map("nine_box")
}

// Categorias de configuração do Nine Box (definidas conforme TABELA DE REFERÊNCIA ORIGEM)
// Usado para exibir perfil e plano de ação de cada quadrante
model NineBoxCategoria {
  id              String   @id @default(uuid())
  codigo          String   @unique  // Ex: "Q1", "Q2", ..., "Q9"
  potencialClasse String   // "Baixo", "Médio" ou "Alto"
  desempenhoClasse String  // "Baixo", "Médio" ou "Alto"
  nome            String   // Ex: "Q1 (Insuficiente)"
  tipo            String   // Ex: "Insuficiente", "Questionável", "Eficaz", etc.
  perfil          String   // Descrição do perfil do profissional nesta categoria
  planoAcao       String   // Plano de ação recomendado para esta categoria
  icon            String?  // Ícone opcional (ex: classe CSS ou nome do ícone)
  cor             String?  // Cor opcional (ex: código hex para estilização)

  @@map("nine_box_categorias")
}

// Valores permitidos para o campo "tipo" de Competency:
// - "desempenho": competências que impactam diretamente a performance do colaborador
// - "potencial": competências que indicam potencial de crescimento e desenvolvimento
//
// Mapeamento para cálculo do Nine Box:
// - Performance (Eixo X) = média das notas de competências tipo "desempenho"
// - Potential (Eixo Y) = média das notas de competências tipo "potencial"
model Competency {
  id            String               @id @default(uuid())
  nome          String               @unique
  descricao     String
  tipo          String               // Apenas: "desempenho" ou "potencial"
  competenciaDe String
  criterios     String[]
  deletedAt     DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  campaigns     CampaignCompetency[]

  @@index([deletedAt])
  @@map("competencies")
}

model AuditLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  action     String
  userId     String
  userTipo   String
  changes    String
  timestamp  DateTime @default(now())

  @@map("audit_logs")
}

model evaluation_templates {
  id        String   @id
  nome      String
  tipo      String
  descricao String?
  criterios Json
  createdAt DateTime @default(now())
  updatedAt DateTime
}

enum UserType {
  admin
  gestor
  colaborador
}

enum CampaignStatus {
  planejamento
  ativa
  finalizada
}
